# ===================================================================
# The Audiopheliac - Production .gitignore
# ===================================================================

# -----------------------------
# OS / System Files
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------
# Editor / IDE
# -----------------------------
.vscode/
.idea/
*.code-workspace

# -----------------------------
# Environment / Secrets
# -----------------------------
.env
.env.*
/config/
!config/music_sources.json
*.key
*.pem

# License keys / software activation: never commit anywhere in the tree
keys/
**/keys/
**/Keys/
*.lic
*.license
**/Software_and_Keys.md
**/Software_Licenses.md
**/*_Licenses.md
**/*_License_Keys.md

# -----------------------------
# Python
# -----------------------------
.venv/
env/
venv/
__pycache__/
*.pyc

# -----------------------------
# Ableton Live / Audio Production
# -----------------------------
# Cache + temp (critical to ignore)
Ableton Cache/
Ableton Temp/
*.asd

# Freeze / render junk
Freeze/
*.wav.tmp
*.aif.tmp

# -----------------------------
# Sample Libraries (DO NOT TRACK)
# -----------------------------
Splice Samples/
Samples/
*.flac
*.wav
*.aiff

# -----------------------------
# Generated Data (regenerable, never tracked)
# -----------------------------
data/**
!data/**/.gitkeep

# -----------------------------
# NAS / Sync / Cloud Garbage
# -----------------------------
.tmp.driveupload/
.tmp.drivedownload/
*.sync
*.qsync

# -----------------------------
# Logs
# -----------------------------
*.log

# -----------------------------
# Optional (uncomment if needed)
# -----------------------------
# Renders/
# Exports/
# Stems/

# Development working files (not tracked)
_dev/
_morning-preview/
# External vendored libraries (kept on NAS, not in repo)
docs/guitar-literacy/guitar/external/
# Cross-project contamination guard (added after quarantine 2026-04-21)
VeteranIntel Development/

# -----------------------------
# Windows utilities / tools (disk-only, not project content)
# -----------------------------
MultiMonitorTool/
skills/
equipment_spec_sheets/

# Suno workspace (creative drafts, account exports, PII — local only)
Suno/

# Paperclip agent run logs (reproducible scan/review outputs)
paperclip-runs/

# Stray AI image exports at root (ChatGPT, Gemini exports)
ChatGPT Image*.png
Gemini_Generated*.png
Googe Cloud Admin/

# Node modules (if ever scaffolded locally)
node_modules/

# Cockpit local state (per-machine, not source-controlled)
console/playlist.json
console/roon_token.json
console/roon_core.json
console/.venv/
console/spotify_token.json
console/spotify_secret.json
console/cockpit_state.json
console/launch_error.log

# Claude Code — machine-local settings (per-machine permission overrides; not shared)
.claude/settings.local.json

# Task Observer meta-skill — private per-project state (S89 install, 2026-05-14)
# Skill bundle in task-observer/ is upstream CC BY 4.0 and is committed.
# Logs and staged updates are private observations from this user's sessions.
/skill-observations/
/skill-updates/
